# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — needed for admin operations (user invites, seeding)
# Get from: Supabase Dashboard → Settings → API → service_role (secret)
# ⚠ NEVER expose this client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma database connection
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Site URL for email redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin seed overrides (optional)
# ADMIN_EMAIL=admin@coastaleats.com
# ADMIN_PASSWORD=ShiftSync2026!
# ADMIN_NAME=System Admin
